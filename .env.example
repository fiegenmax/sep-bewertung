# Kopiere diese Datei zu .env und trage deine echten Werte ein.
# .env ist in .gitignore und darf NIE committet werden.

# GitLab Personal Access Token (read_api scope reicht)
# Holst du dir hier: https://gitlab.git.nrw/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Anthropic API Key fuer LLM-gestuetzte Inhaltspruefung (Claude Haiku)
# Optional: ohne diesen Key faellt das Tool auf reine Heuristik zurueck.
# Holst du dir hier: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
